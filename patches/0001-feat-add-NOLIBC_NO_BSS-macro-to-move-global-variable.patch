From 495c63183ee345ff20d9713716ebf2bd341b7e20 Mon Sep 17 00:00:00 2001
From: WaferJay <me@wanfajie.com>
Date: Sun, 7 Jun 2026 20:51:08 +0800
Subject: [PATCH 1/3] feat: add NOLIBC_NO_BSS macro to move global variables
 from .bss to .data

---
 include/nolibc/crt.h   | 5 +++++
 include/nolibc/errno.h | 4 ++++
 2 files changed, 9 insertions(+)

diff --git a/include/nolibc/crt.h b/include/nolibc/crt.h
index 961cfe7..35976d4 100644
--- a/include/nolibc/crt.h
+++ b/include/nolibc/crt.h
@@ -9,8 +9,13 @@
 
 #include "compiler.h"
 
+#ifdef NOLIBC_NO_BSS
+char **environ __attribute__((weak,section(".data")));
+const unsigned long *_auxv __attribute__((weak,section(".data")));
+#else
 char **environ __attribute__((weak));
 const unsigned long *_auxv __attribute__((weak));
+#endif
 
 void _start(void);
 static void __stack_chk_init(void);
diff --git a/include/nolibc/errno.h b/include/nolibc/errno.h
index 08a33c4..7a1d4f4 100644
--- a/include/nolibc/errno.h
+++ b/include/nolibc/errno.h
@@ -14,7 +14,11 @@
 
 #ifndef NOLIBC_IGNORE_ERRNO
 #define SET_ERRNO(v) do { errno = (v); } while (0)
+#ifdef NOLIBC_NO_BSS
+int errno __attribute__((weak,section(".data")));
+#else   // NOLIBC_NO_BSS
 int errno __attribute__((weak));
+#endif  // NOLIBC_NO_BSS
 #else
 #define SET_ERRNO(v) do { } while (0)
 #endif
-- 
2.51.0

